# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# Comma separated list of allowed browser origins for CORS / Socket.IO.
# Use * only for local development.
CLIENT_ORIGIN=http://localhost:4000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/gians_voip

# ---------------------------------------------------------------------------
# Authentication
# Generate strong values:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---------------------------------------------------------------------------
# WebRTC ICE servers
# STUN is enough for most home networks. TURN is REQUIRED for symmetric NAT /
# mobile carrier networks. Run your own coturn (see docs/DEPLOYMENT.md).
# ---------------------------------------------------------------------------
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Leave TURN_URLS empty to disable TURN.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# When set, the server issues short-lived HMAC TURN credentials (coturn
# `use-auth-secret` / REST API mode) instead of the static ones above.
TURN_STATIC_SECRET=
TURN_CREDENTIAL_TTL=86400

# ---------------------------------------------------------------------------
# Web Push (VAPID)
#
# This is what makes a call ring a device whose browser is CLOSED or whose
# screen is locked. Without it, calls only ring while the app is open.
# Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---------------------------------------------------------------------------
# Call behaviour
# ---------------------------------------------------------------------------
# How long an unanswered call rings before it is marked as missed (ms).
RING_TIMEOUT_MS=45000
