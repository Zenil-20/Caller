<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Android 13+ requires the user to grant notifications at runtime. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      The permission this whole app exists for: without it a call notification
      is downgraded to an ordinary heads-up banner and no call screen appears.

      Android 14 restricted it to calling and alarm apps, but that restriction is
      enforced by the Play Store installer revoking it after install — the
      platform still grants it at install time. A sideloaded build never passes
      through that revocation, so it keeps it. The app checks at runtime anyway
      and can send the user to Settings if some OEM has taken it away.
    -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Android 11+ package visibility: without this the TWA cannot find Chrome. -->
    <queries>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gians"
        tools:targetApi="36">

        <!--
          The launcher. Subclasses android-browser-helper's LauncherActivity so
          the FCM token can be appended to the URL Chrome opens — that is how the
          web page learns which device to register, without this shell ever
          needing a login of its own.
        -->
        <activity
            android:name=".GiansLauncherActivity"
            android:exported="true"
            android:label="@string/app_name">

            <meta-data
                android:name="android.support.customtabs.trusted.DEFAULT_URL"
                android:value="${hostUrl}" />
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR"
                android:resource="@color/brand" />
            <meta-data
                android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR"
                android:resource="@color/brand" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Claims the site's links, so verified URLs open in the app. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="${hostName}" />
            </intent-filter>
        </activity>

        <!--
          The full-screen ringing call screen.

          Every attribute here is load-bearing:
            showWhenLocked/turnScreenOn  draw over the keyguard and wake the
                                         display. Declared statically rather than
                                         called in onCreate because the runtime
                                         calls race the first frame, and that race
                                         is what aggressive OEM ROMs lose.
            singleInstance + taskAffinity keep the call screen out of the TWA's
                                         task, so answering does not bury it.
            excludeFromRecents           a ringing call is not history.
        -->
        <activity
            android:name=".IncomingCallActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:theme="@style/Theme.Gians.Call" />

        <service
            android:name=".CallMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Declining from the notification, without opening anything. -->
        <receiver
            android:name=".CallActionReceiver"
            android:exported="false" />

        <!-- Firebase would otherwise pick its own; keep it consistent. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/brand" />
    </application>
</manifest>
